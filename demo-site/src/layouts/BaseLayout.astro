---
import '../styles/global.css';
import type { Shop } from '../data/shops';
import { getTheme } from '../themes/restaurantThemes';
import { resolveOgpSrc } from '../data/demoAssets';

interface Props {
  shop: Shop;
}
const { shop } = Astro.props;
const theme = getTheme(shop.theme);
const c = theme.colors;

// テーマ色とフォントを :root に注入（Tailwind の var(--c-*) と連動）
const rootVars = `:root{
  --c-bg:${c.bg};--c-surface:${c.surface};--c-surface-alt:${c.surfaceAlt};
  --c-text:${c.text};--c-muted:${c.muted};--c-accent:${c.accent};
  --c-accent-ink:${c.accentInk};--c-border:${c.border};
  --font-heading:${theme.fontHeading};--font-body:${theme.fontBody};
  --tracking:${theme.headingTracking};
}`;
// OGP: approved ogp → approved hero → ローカル汎用OGP。外部ランダムURLは使わない。
const og = new URL(resolveOgpSrc(shop.assetCategory, shop.mood), Astro.site ?? 'https://demo.example.com').toString();
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{shop.seo.title}</title>
    <meta name="description" content={shop.seo.description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href={theme.fontHref} rel="stylesheet" />

    <!-- OGP -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={shop.seo.title} />
    <meta property="og:description" content={shop.seo.description} />
    <meta property="og:image" content={og} />
    <meta property="og:locale" content="ja_JP" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={shop.seo.title} />
    <meta name="twitter:description" content={shop.seo.description} />
    <meta name="twitter:image" content={og} />

    <style set:html={rootVars}></style>
    <noscript><style>{`.reveal{opacity:1 !important;transform:none !important}`}</style></noscript>
  </head>
  <body class="font-body text-ink">
    <slot />
    <script is:inline>
      (function () {
        var els = document.querySelectorAll('.reveal');
        if (!els.length) return;
        if (!('IntersectionObserver' in window)) {
          els.forEach(function (e) {
            e.classList.add('in');
          });
          return;
        }
        var io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (en) {
              if (en.isIntersecting) {
                en.target.classList.add('in');
                io.unobserve(en.target);
              }
            });
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.08 }
        );
        els.forEach(function (e) {
          io.observe(e);
        });
      })();
    </script>
  </body>
</html>
