---
import type { Shop } from '../data/shops';
import { radii, type RestaurantTheme } from '../themes/restaurantThemes';

interface Props {
  shop: Shop;
  theme: RestaurantTheme;
}
const { shop, theme } = Astro.props;
const r = radii(theme);
---

<section class="mx-auto max-w-content px-5 py-12 sm:py-16">
  <p class="text-xs tracking-[0.3em] text-accent">SCENE</p>
  <h2 class="mt-2 font-heading text-2xl text-ink sm:text-3xl" style="letter-spacing:var(--tracking)">
    こんなシーンに
  </h2>
  <div class="mt-8 grid gap-4 sm:grid-cols-3">
    {
      shop.scenes.map((s) => (
        <div class={`border border-line bg-surface p-5 ${r.card}`}>
          <p class="font-heading text-base text-accent">{s.label}</p>
          <p class="mt-2 text-sm leading-relaxed text-muted">{s.body}</p>
        </div>
      ))
    }
  </div>
</section>
