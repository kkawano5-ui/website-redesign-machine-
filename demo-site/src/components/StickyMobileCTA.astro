---
import type { Shop } from '../data/shops';

interface Props {
  shop: Shop;
}
const { shop } = Astro.props;
const mapHref = `https://maps.google.com/maps?q=${encodeURIComponent(shop.access.mapQuery)}`;
---

<!-- スマホ専用の固定CTA（電話する / 地図を見る / Instagramを見る） -->
<nav class="fixed inset-x-0 bottom-0 z-40 border-t border-line bg-bg/95 backdrop-blur sm:hidden">
  <div class="grid grid-cols-3 divide-x divide-line">
    <a href={`tel:${shop.cta.phone}`} class="flex flex-col items-center gap-1 py-3 text-[11px] font-medium text-ink" aria-label="電話する">
      <svg viewBox="0 0 24 24" class="h-5 w-5 text-accent" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z" />
      </svg>
      電話する
    </a>
    <a href={mapHref} target="_blank" rel="noopener" class="flex flex-col items-center gap-1 py-3 text-[11px] font-medium text-ink" aria-label="地図を見る">
      <svg viewBox="0 0 24 24" class="h-5 w-5 text-accent" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0Z" />
        <circle cx="12" cy="10" r="3" />
      </svg>
      地図を見る
    </a>
    <a href={shop.cta.instagram ?? '#'} target="_blank" rel="noopener" class="flex flex-col items-center gap-1 py-3 text-[11px] font-medium text-ink" aria-label="Instagramを見る">
      <svg viewBox="0 0 24 24" class="h-5 w-5 text-accent" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="3" width="18" height="18" rx="5" />
        <circle cx="12" cy="12" r="4" />
        <line x1="17.5" y1="6.5" x2="17.5" y2="6.5" />
      </svg>
      Instagram
    </a>
  </div>
</nav>
<div class="h-16 sm:hidden"></div>
