---
import AssetImage from './AssetImage.astro';
import type { Shop } from '../data/shops';
import { radii, type RestaurantTheme } from '../themes/restaurantThemes';

interface Props {
  shop: Shop;
  theme: RestaurantTheme;
}
const { shop, theme } = Astro.props;
const r = radii(theme);
const cat = shop.assetCategory;
const mood = shop.mood;
---

<section class="mx-auto max-w-content px-5 py-12 sm:py-16">
  <p class="text-xs tracking-[0.3em] text-accent">ABOUT</p>
  <h2 class="mt-2 font-heading text-2xl text-ink sm:text-3xl" style="letter-spacing:var(--tracking)">
    {shop.name}のこだわり
  </h2>

  <div class="mt-8 grid gap-8 sm:grid-cols-2 sm:items-center">
    <div class="grid grid-cols-2 gap-3">
      <AssetImage category={cat} role="interior" index={0} mood={mood} ratio="aspect-[3/4]" rounded={r.img} class="row-span-2" />
      <AssetImage category={cat} role="detail" index={0} mood={mood} ratio="aspect-square" rounded={r.img} />
      <AssetImage category={cat} role="atmosphere" index={0} mood={mood} ratio="aspect-square" rounded={r.img} />
    </div>

    <div class="space-y-6">
      {
        shop.about.map((a, i) => (
          <div class="border-l-2 border-accent pl-4">
            <span class="font-heading text-sm text-accent">0{i + 1}</span>
            <h3 class="mt-1 font-heading text-lg text-ink">{a.title}</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-muted">{a.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
